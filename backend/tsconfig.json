{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": [
    "src/api/**/*",
    "src/routes/mobileApiRoutes/**/*",
    "src/routes/adminDashboardApiRoutes/**/*",
    "src/models/**/*",
    "src/openai/**/*",
    "src/types/**/*",
    "src/middlewares/**/*",
    "src/utils/**/*",
    "dist",
    "node_modules"
  ]
}
